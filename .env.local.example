# ──────────────────────────────────────────────────────────────────────────────
# AI providers (required)
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Cloud / Supabase (scaffold — leave NEXT_PUBLIC_USE_CLOUD=false to keep localStorage)
# ──────────────────────────────────────────────────────────────────────────────
# Create project at https://supabase.com, then apply lib/supabase/schema.sql.
# Get URL + anon key from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER ONLY. Never expose. Used by lib/supabase/server.ts for
# admin tasks (migrations, batch ops). Skip if not running server-side admin code yet.
SUPABASE_SERVICE_ROLE_KEY=

# Flip to true to switch reads/writes to Supabase. Default false keeps localStorage.
# To enable: 1) set this true, 2) install @supabase/supabase-js @supabase/ssr,
# 3) apply lib/supabase/schema.sql, 4) implement Auth UI (magic link recommended).
NEXT_PUBLIC_USE_CLOUD=false
